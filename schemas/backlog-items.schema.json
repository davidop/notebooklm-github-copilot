{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/davidop/notebooklm-github-copilot/schemas/backlog-items.schema.json",
  "title": "Backlog Items",
  "description": "An array of user story backlog items generated from NotebookLM sources.",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "type", "title", "user_story", "acceptance_criteria", "source"],
    "properties": {
      "id": {
        "type": "string",
        "description": "Unique identifier for the backlog item (e.g. US-001)",
        "pattern": "^(US|TASK|EPIC|FEAT|BUG)-[0-9]{3,}$"
      },
      "type": {
        "type": "string",
        "description": "Work item type",
        "enum": ["Epic", "Feature", "UserStory", "Task", "Bug", "Impediment"]
      },
      "title": {
        "type": "string",
        "description": "Short title for the backlog item",
        "minLength": 5,
        "maxLength": 150
      },
      "user_story": {
        "type": "string",
        "description": "User story in 'As a / I want / so that' format (required for UserStory type)",
        "minLength": 10
      },
      "acceptance_criteria": {
        "type": "array",
        "description": "Testable acceptance criteria for this item",
        "items": { "type": "string" },
        "minItems": 1
      },
      "priority": {
        "type": "integer",
        "description": "Priority: 1 (highest) to 4 (lowest)",
        "minimum": 1,
        "maximum": 4
      },
      "estimate_points": {
        "type": "number",
        "description": "Story point estimate",
        "minimum": 0
      },
      "labels": {
        "type": "array",
        "description": "Labels or tags for the item",
        "items": { "type": "string" }
      },
      "parent_id": {
        "type": "string",
        "description": "ID of the parent Epic or Feature"
      },
      "source": {
        "type": "string",
        "description": "NotebookLM source document that grounds this item",
        "minLength": 3
      },
      "notes": {
        "type": "string",
        "description": "Additional notes or clarifications"
      },
      "ungrounded": {
        "type": "boolean",
        "description": "True if this item could not be grounded in notebook sources",
        "default": false
      }
    },
    "additionalProperties": false
  }
}
