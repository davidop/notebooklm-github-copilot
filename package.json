{
  "name": "notebooklm-github-copilot",
  "version": "0.1.0",
  "private": true,
  "description": "Connect GitHub Copilot with NotebookLM through MCP for source-grounded coding, architecture, and presales workflows.",
  "type": "module",
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "mcp:notebooklm": "npx notebooklm-mcp@latest",
    "mcp:notebooklm:http": "npx notebooklm-mcp@latest --transport http --port 3000",
    "pin:notebooklm": "node scripts/pin-notebooklm-version.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {}
}
