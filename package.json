{
  "name": "notebooklm-github-copilot",
  "version": "0.4.0",
  "private": true,
  "description": "Connect GitHub Copilot with NotebookLM through MCP for source-grounded coding, architecture, and presales workflows.",
  "type": "module",
  "keywords": [
    "notebooklm",
    "github-copilot",
    "mcp",
    "model-context-protocol",
    "vscode",
    "ai-agents",
    "grounded-ai",
    "architecture",
    "presales",
    "azure",
    "demo",
    "setup-wizard"
  ],
  "scripts": {
    "validate": "node scripts/validate.mjs",
    "smoke:test": "node scripts/smoke-test.mjs",
    "mcp:notebooklm": "npx notebooklm-mcp@latest",
    "mcp:notebooklm:http": "npx notebooklm-mcp@latest --transport http --port 3000",
    "pin:notebooklm": "node scripts/pin-notebooklm-version.mjs",
    "lint:markdown": "npx markdownlint-cli2@0.14.0 \"**/*.md\" --ignore node_modules",
    "check:links": "node scripts/check-links.mjs",
    "check:recipes": "node scripts/check-recipes.mjs",
    "check:prompts": "node scripts/check-prompts.mjs",
    "check:frontmatter": "node scripts/check-frontmatter.mjs",
    "check:schemas": "node scripts/check-schemas.mjs",
    "check:site": "node scripts/check-site.mjs",
    "check:repo": "npm run validate && npm run check:links && npm run check:recipes && npm run check:prompts && npm run check:frontmatter && npm run check:schemas && npm run check:site",
    "docs:index": "node scripts/generate-doc-index.mjs",
    "setup:wizard": "node scripts/setup-wizard.mjs",
    "setup:vscode": "node scripts/generate-client-config.mjs --client vscode --version latest --output .vscode/mcp.json",
    "setup:opencode": "node scripts/generate-client-config.mjs --client opencode --version latest --output opencode.jsonc",
    "setup:cursor": "node scripts/generate-client-config.mjs --client cursor --version latest --output .cursor/mcp.json",
    "doctor": "node scripts/doctor.mjs",
    "release:notes": "node scripts/release-notes.mjs"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {}
}
